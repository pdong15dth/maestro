{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Maestro IDE",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-read-dir",
      "allow": [{"path": "$APPDATA"}, {"path": "$APPDATA/**"}, {"path": "$HOME"}, {"path": "$HOME/**"}, {"path": "**"}]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [{"path": "$APPDATA"}, {"path": "$APPDATA/**"}, {"path": "$HOME"}, {"path": "$HOME/**"}, {"path": "**"}]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{"path": "$APPDATA"}, {"path": "$APPDATA/**"}, {"path": "$HOME"}, {"path": "$HOME/**"}, {"path": "**"}]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [{"path": "$APPDATA"}, {"path": "$APPDATA/**"}, {"path": "$HOME"}, {"path": "$HOME/**"}, {"path": "**"}]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [{"path": "$APPDATA"}, {"path": "$APPDATA/**"}, {"path": "$HOME"}, {"path": "$HOME/**"}, {"path": "**"}]
    },
    "store:default"
  ]
}
