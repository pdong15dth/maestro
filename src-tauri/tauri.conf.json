{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maestro",
  "version": "0.1.0",
  "identifier": "com.maestro.ai-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Maestro",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true,
        "visible": false
      },
      {
        "label": "splashscreen",
        "url": "splash.html",
        "width": 480,
        "height": 340,
        "center": true,
        "decorations": false,
        "transparent": true,
        "fullscreen": false,
        "resizable": false,
        "alwaysOnTop": true,
        "visible": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
